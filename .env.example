# ==============================================
# DATABASE & AUTHENTICATION
# ==============================================

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ==============================================
# EXTERNAL APIS
# ==============================================

# Google Maps API (for maps, routes, places, traffic, directions)
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Required APIs: Maps JavaScript API, Places API, Directions API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenWeatherMap API (for weather data)
# Get your API key from: https://openweathermap.org/api
# Free tier: 1,000 calls/day
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key_here

# ==============================================
# AI & RECOMMENDATIONS (Optional)
# ==============================================

# OpenAI API (for AI-powered recommendations and itinerary generation)
# Get your API key from: https://platform.openai.com/api-keys
# Used in: lib/ai/recommendations.ts
OPENAI_API_KEY=your_openai_api_key_here

# ==============================================
# PAYMENT GATEWAY (Optional - for Phase 8)
# ==============================================

# Stripe (Recommended for international payments)
# Get your keys from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Razorpay (Alternative for Indian payments)
# Get your keys from: https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ==============================================
# MONITORING & ANALYTICS (Optional)
# ==============================================

# Sentry (Error Tracking) - https://sentry.io/
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Google Analytics - https://analytics.google.com/
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Alert Webhook URL (for critical error notifications)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Performance monitoring settings
# NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
# NEXT_PUBLIC_LOG_LEVEL=info

# Sentry (for error tracking)
# Get your DSN from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Google Analytics (for usage analytics)
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_measurement_id_here

# ==============================================
# APPLICATION SETTINGS
# ==============================================

# Application URL (for callbacks and webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment
NODE_ENV=development
